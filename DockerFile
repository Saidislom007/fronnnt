# 1-bosqich: Build qilish
FROM node:18-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm install

COPY . .

# Railway build o'zgaruvchilarini qabul qilish
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

# Vite build natijani 'dist' papkasiga tashlaydi
RUN npm run build

# 2-bosqich: Nginx orqali tarqatish
FROM nginx:stable-alpine

# DIQQAT: Vite-da 'dist' papkasidan nusxa olinadi (React-da 'build' edi)
COPY --from=build /app/dist /usr/share/nginx/html

# SPA (Single Page Application) uchun Nginx konfiguratsiyasini to'g'rilash
# Sahifani refresh qilganda 404 chiqmasligi uchun kerak
RUN echo 'server { \
    listen 80; \
    location / { \
        root /usr/share/nginx/html; \
        index index.html; \
        try_files $uri $uri/ /index.html; \
    } \
}' > /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]