# 1-bosqich: Build qilish
FROM node:18-alpine AS build
WORKDIR /app

# Bog'liqliklarni o'rnatish
COPY package.json package-lock.json ./
RUN npm install

# Kodni nusxalash va build qilish
COPY . .
# Railway uchun API URL'ni build vaqtida berish mumkin
ARG REACT_APP_API_URL
ENV REACT_APP_API_URL=$REACT_APP_API_URL

RUN npm run build

# 2-bosqich: Statik fayllarni xizmat qilish (Nginx)
FROM nginx:stable-alpine
# Build qilingan fayllarni Nginx'ga nusxalash
COPY --from=build /app/build /usr/share/nginx/html

# Nginx sozlamasini (React Router uchun) nusxalash (ixtiyoriy)
# COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]