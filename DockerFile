# 1-bosqich: Node obrazini tanlaymiz
FROM node:18-alpine
WORKDIR /app

# Bog'liqliklarni o'rnatish
COPY package.json package-lock.json ./
RUN npm install

# Loyiha kodini nusxalash
COPY . .

# Railway build o'zgaruvchisini qabul qilish
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

# Loyihani build qilish
RUN npm run build

# Portni ochish
EXPOSE 5173

# Vite-ni barcha interfeyslar (0.0.0.0) uchun 5173 portida ishga tushiramiz
# --host 0.0.0.0 qatori 502 xatosini yo'qotish uchun ENG MUHIMI
CMD ["npx", "vite", "preview", "--host", "0.0.0.0", "--port", "5173"]