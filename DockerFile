FROM node:18-alpine

WORKDIR /app

# Bog'liqliklarni o'rnatish
COPY package.json ./
# package-lock.json bo'lsa uni ham qo'shing, bo'lmasa pastdagini o'zi yetarli
RUN npm install

COPY . .

# Railway uchun build o'zgaruvchisi
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

# Loyihani build qilish
RUN npm run build

# Vite-ni 0.0.0.0 hostida va 5173 portida majburiy yurgizish
# --host 0.0.0.0 bo'lmasa Railway serveringizni ko'ra olmaydi (502 beradi)
EXPOSE 5173
CMD ["npx", "vite", "preview", "--host", "0.0.0.0", "--port", "5173"]